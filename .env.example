# Conductor — Environment Configuration
# Copy this file to .env and fill in the values.

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://conductor:conductor@localhost:5432/conductor

# ─── Server ─────────────────────────────────────────────────
# The address the HTTP + WebSocket server binds to.
CONDUCTOR_HOST=0.0.0.0
CONDUCTOR_PORT=7878

# ─── Workspace ──────────────────────────────────────────────
# Root directory where project workspaces are mounted.
CONDUCTOR_WORKSPACE_ROOT=/workspace

# ─── Agent Defaults ─────────────────────────────────────────
# Maximum tokens before context compaction triggers.
CONDUCTOR_MAX_CONTEXT_TOKENS=80000

# Hard timeout for a single agent session (seconds).
CONDUCTOR_SESSION_TIMEOUT_SECS=3600

# ─── Logging ────────────────────────────────────────────────
# RUST_LOG=conductor=debug,sqlx=warn,tower_http=debug
RUST_LOG=info
